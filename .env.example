# ════════════════════════════════════════════════════════════════════════════
# KX AI - PERSONAL ADVISOR (JARVIS EDITION) ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` (`cp .env.example .env`) and paste your keys below.
# Almost all providers listed below have generous FREE TIERS ($0 cost).

# ─────────────────────────────────────────────────────────────────────────────
# 1. COGNITIVE BRAIN: LLM PROVIDERS (7-Provider Resilient Super-Stack)
# ─────────────────────────────────────────────────────────────────────────────

# Priority 1: Groq (Fastest overall open-source LPU inference)
# ── Free Tier: 30 requests/min, 14,400 requests/day
# ── Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Priority 2: Cerebras Cloud (Instantaneous speech turn-taking >2000 tokens/sec)
# ── Free Tier: 1 Million free tokens/day, ~30k tokens/min
# ── Get key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# Priority 3: Google Gemini API (Massive 1M+ context & Arabic/Hausa fluency)
# ── Free Tier: 1,500 requests/day, 1 Million TPM, 15 RPM (Completely Free!)
# ── Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Priority 4: Mistral AI (World-class code generation & syntax refactoring)
# ── Free Tier: Free developer experimentation plan
# ── Get key: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=...

# Priority 5: OpenRouter (Unified gateway to 100+ models, ultimate fallback)
# ── Free Tier: 20+ permanent :free model routes (DeepSeek R1, Qwen 2.5)
# ── Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Priority 6: NVIDIA NIM (Enterprise LLM preview microservices)
# ── Free Tier: Developer prototyping grants
# ── Get key: https://build.nvidia.com/nim
NVIDIA_NIM_API_KEY=nvapi-...

# Priority 7: Ollama (Local offline inference, zero cost forever)
# ── Setup: Install from https://ollama.ai and run `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# Optional Frontier: OpenAI direct API (Paid / Pay-as-you-go)
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# 2. AGENTIC PERCEPTION: WEB SEARCH PROVIDERS (Live Internet Access)
# ─────────────────────────────────────────────────────────────────────────────

# Recommended Agent Search: Tavily AI (Designed specifically for AI agents)
# ── Free Tier: 1,000 API searches/month FREE
# ── Get key: https://tavily.com
TAVILY_API_KEY=tvly-...

# Option B: SerpAPI (Clean Google Search result scraper)
# ── Free Tier: 100 searches/month FREE
# ── Get key: https://serpapi.com
SERPAPI_KEY=...

# Option C: Google Custom Search API (Official Google JSON API)
# ── Free Tier: 100 searches/day FREE
# ── Get key: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# ── Get Engine ID: https://programmablesearchengine.google.com/controlpanel/all
GOOGLE_SEARCH_API_KEY=...
GOOGLE_SEARCH_ENGINE_ID=...

# Option D: Bing Search API (Microsoft Azure)
# ── Get key: https://portal.azure.com (Search for 'Bing Search v7')
BING_SEARCH_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# 3. VOICE & SPEECH (ASR Speech-to-Text & Neural TTS)
# ─────────────────────────────────────────────────────────────────────────────

# Recommended Neural TTS: ElevenLabs (Hyper-realistic multilingual voices)
# ── Get key: https://elevenlabs.io/api
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Recommended Real-Time Voice: DeepGram (Ultra-low latency <300ms transcription)
# ── Free Tier: $20 in free credit upon sign-up (~100 hours of audio!)
# ── Get key: https://console.deepgram.com
DEEPGRAM_API_KEY=...

# Option B: AssemblyAI (High accuracy speech recognition & speaker diarization)
# ── Free Tier: $5 free credit upon sign-up (~15+ hours)
# ── Get key: https://www.assemblyai.com
ASSEMBLYAI_API_KEY=...

# Option C: Google Cloud Speech API
GOOGLE_CLOUD_PROJECT_ID=...
GOOGLE_CLOUD_KEY_PATH=...

# ─────────────────────────────────────────────────────────────────────────────
# 4. CREATIVE MEDIA: IMAGE & VIDEO GENERATION
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face Serverless API (Free Stable Diffusion & FLUX image gen)
# ── Free Tier: Unlimited serverless inference under fair-use limits
# ── Get token: https://huggingface.co/settings/tokens (Read access)
HUGGINGFACE_API_KEY=hf_...

# Replicate API (State of the art video gen like Kling, Luma, Flux)
# ── Pricing: Few cents per video run
# ── Get key: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_...

# ─────────────────────────────────────────────────────────────────────────────
# 5. ADVISOR MEMORY & KNOWLEDGE BASE (Database & RAG)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres Cloud (Persistent user profiles, chat history, pgvector)
# ── Free Tier: 2 cloud database projects up to 500MB FREE FOREVER
# ── Get credentials: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_KEY=eyJh...

# Chroma DB Local Vector Store (For codebase & PDF RAG embeddings)
# ── Cost: $0 (Runs locally inside SQLite file, no cloud account needed!)
CHROMA_DB_PATH=./db/chroma.sqlite3

# Hugging Face Dataset Publishing (For red-teaming cognition research)
HF_TOKEN=hf_...
HF_DATASET_REPO=username/dataset-name

# ─────────────────────────────────────────────────────────────────────────────
# 6. SECURITY & SERVER PORTS
# ─────────────────────────────────────────────────────────────────────────────

PORT=7860
CORS_ORIGIN=*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Access Tier Key Management (For customer service & multi-user role gating)
GODMODE_TIER_KEYS=enterprise:key1,pro:key2,free:key3

# ─────────────────────────────────────────────────────────────────────────────
# 7. FEATURE FLAGS (Turn JARVIS capabilities on/off)
# ─────────────────────────────────────────────────────────────────────────────

ENABLE_IMAGE_GENERATION=true
ENABLE_VIDEO_GENERATION=false
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_FILE_UPLOAD=true
ENABLE_RAG=true

LOG_LEVEL=info
DEBUG=false
ENABLE_TELEMETRY=true
