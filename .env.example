# ════════════════════════════════════════════════════════════════════════════
# KX AI - Personal Advisor Environment Configuration
# ════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# LLM PROVIDERS (Multi-Provider Support)
# ─────────────────────────────────────────────────────────────────────────────

# Priority 1: OpenRouter (100+ models, fallback for everything)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Priority 2: Groq (Fastest inference, free tier available)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Priority 3: NVIDIA NIM (Enterprise-grade, free tier available)
# Get key: https://build.nvidia.com/nim
NVIDIA_NIM_API_KEY=nvapi-...

# Priority 4: Ollama (Local inference, zero cost)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenAI (if you have budget)
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# WEB SEARCH PROVIDERS (Multi-Provider Fallback)
# ─────────────────────────────────────────────────────────────────────────────

# Priority 1: SerpAPI
SERPAPI_KEY=...

# Priority 2: Google Custom Search
GOOGLE_SEARCH_API_KEY=...
GOOGLE_SEARCH_ENGINE_ID=...

# Priority 3: Bing Search
BING_SEARCH_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# IMAGE & VIDEO GENERATION (Future)
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face (Stable Diffusion)
HUGGINGFACE_API_KEY=hf_...

# Replicate (Various models)
REPLICATE_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# VOICE & AUDIO (Future)
# ─────────────────────────────────────────────────────────────────────────────

# Google Cloud Speech-to-Text
GOOGLE_CLOUD_PROJECT_ID=...
GOOGLE_CLOUD_KEY_PATH=...

# AssemblyAI (Real-time transcription)
ASSEMBLYAI_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE & STORAGE
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (for persistent memory)
SUPABASE_URL=https://....supabase.co
SUPABASE_KEY=...

# Vector Database (Chroma or similar)
CHROMA_DB_PATH=./db/chroma.sqlite3

# HuggingFace Dataset Publishing
HF_TOKEN=hf_...
HF_DATASET_REPO=username/dataset-name

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# API Port
PORT=7860

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Tier Configuration
GODMODE_TIER_KEYS=enterprise:key1,pro:key2,free:key3

# ─────────────────────────────────────────────────────────────────────────────
# PERSONALIZATION & STATE
# ─────────────────────────────────────────────────────────────────────────────

# User Profile Storage
USER_PROFILE_DB=./db/user_profiles.json

# Conversation Memory
MEMORY_TTL_HOURS=24
MAX_MEMORY_ENTRIES=10000

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable features
ENABLE_IMAGE_GENERATION=false
ENABLE_VIDEO_GENERATION=false
ENABLE_VOICE_INPUT=false
ENABLE_VOICE_OUTPUT=false
ENABLE_FILE_UPLOAD=false
ENABLE_RAG=false

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING & DEBUG
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info
DEBUG=false
ENABLE_TELEMETRY=true
