{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KX Autonomous AI",
  "version": "0.4.0",
  "identifier": "ai.greenbyte.kx-advisor",
  "build": {
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "KX Autonomous AI (Sanctuary OS)",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; connect-src 'self' https://openrouter.ai https://*.groq.com https://*.deepgram.com"
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
